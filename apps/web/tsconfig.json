{
  "extends": "../../packages/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@repo/ui/*": ["../../packages/ui/src/*"],
      "@repo/api-client/*": ["../../packages/api-client/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
